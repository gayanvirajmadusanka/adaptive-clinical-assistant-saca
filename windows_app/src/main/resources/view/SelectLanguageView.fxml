<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.*?>
<AnchorPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.saca.controller.SelectLanguageController"
            prefWidth="900"
            prefHeight="650"
            stylesheets="@/styles/style.css"
            styleClass="root">

    <children>

        <!-- Main centered content -->
        <VBox alignment="CENTER"
              spacing="35"
              prefWidth="900"
              prefHeight="650"
              AnchorPane.topAnchor="0"
              AnchorPane.bottomAnchor="0"
              AnchorPane.leftAnchor="0"
              AnchorPane.rightAnchor="0">

            <padding>
                <Insets top="50" right="50" bottom="50" left="50"/>
            </padding>

            <!-- Title -->
            <Label text="Select Language&#10;Wangka kalu yirrarni"
                   styleClass="language-title"
                   textAlignment="CENTER"
                   alignment="CENTER"
                   wrapText="true"/>

            <!-- Warlpiri Button -->
            <Button text="Warlpiri"
                    prefWidth="300"
                    prefHeight="70"
                    onAction="#handleWarlpiriClick"
                    styleClass="warlpiri-button"/>

            <!-- English Button -->
            <Button text="English"
                    prefWidth="300"
                    prefHeight="70"
                    onAction="#handleEnglishClick"
                    styleClass="english-button"/>
        </VBox>

    </children>

</AnchorPane>
