<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="org.saca.controller.AudioOverlayController"
           fx:id="audioOverlayRoot"
           visible="false"
           managed="false"
           stylesheets="@/styles/style.css"
           styleClass="audio-overlay">

    <VBox alignment="CENTER" spacing="20" styleClass="audio-overlay-card">

        <Label text="Playing audio..."
               styleClass="audio-overlay-text"/>

        <Button text="Stop"
                styleClass="audio-cancel-btn"
                onAction="#handleCancel"/>

    </VBox>

</StackPane>
