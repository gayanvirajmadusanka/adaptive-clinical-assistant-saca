<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.saca.controller.TellUsMoreTextController"
            stylesheets="@/styles/style.css"
            styleClass="root">

    <top>
        <HBox alignment="CENTER_LEFT" styleClass="top-bar">
            <padding>
                <Insets top="10" right="20" bottom="10" left="20"/>
            </padding>
            <Region HBox.hgrow="ALWAYS"/>
        </HBox>
    </top>

    <left>
        <fx:include fx:id="sidebar" source="SidebarView.fxml"/>
    </left>

    <center>
        <ScrollPane fitToWidth="true"
                    fitToHeight="false"
                    pannable="false"
                    styleClass="center-scroll">
            <content>
                <StackPane styleClass="tell-bg">

                    <VBox alignment="TOP_CENTER"
                          spacing="28"
                          maxWidth="800"
                          styleClass="tell-container">

                        <padding>
                            <Insets top="40" right="40" bottom="60" left="40"/>
                        </padding>

                        <HBox alignment="CENTER_LEFT"
                              styleClass="tell-header-bar">

                            <Button onAction="#handleBack"
                                    styleClass="tell-back-btn">
                                <graphic>
                                    <ImageView fitWidth="20" fitHeight="20" preserveRatio="true">
                                        <image>
                                            <Image url="@/icons/back-arrow.png"/>
                                        </image>
                                    </ImageView>
                                </graphic>
                            </Button>

                            <Label text="%tell_us_more"
                                   styleClass="tell-header-title"
                                   HBox.hgrow="ALWAYS"
                                   maxWidth="Infinity"
                                   alignment="CENTER"/>

                            <Region minWidth="38" maxWidth="38"/>

                        </HBox>

                        <GridPane fx:id="questionsGrid"
                                  hgap="24"
                                  vgap="20"
                                  alignment="CENTER"
                                  styleClass="questions-pane">

                            <columnConstraints>
                                <ColumnConstraints
                                        hgrow="ALWAYS"
                                        percentWidth="50"/>
                                <ColumnConstraints
                                        hgrow="ALWAYS"
                                        percentWidth="50"/>
                            </columnConstraints>

                        </GridPane>

                        <Button text="%continue"
                                styleClass="tell-continue-btn"
                                prefWidth="340"
                                onAction="#handleContinue"/>

                    </VBox>
                </StackPane>
            </content>
        </ScrollPane>
    </center>

</BorderPane>
