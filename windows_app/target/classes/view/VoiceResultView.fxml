<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="org.saca.controller.VoiceResultController"
           stylesheets="@/styles/style.css"
           styleClass="root">

    <BorderPane>

        <top>
            <HBox alignment="CENTER_LEFT" styleClass="top-bar">
                <padding>
                    <Insets top="10" right="20" bottom="10" left="20"/>
                </padding>
                <Region HBox.hgrow="ALWAYS"/>
            </HBox>
        </top>

        <left>
            <fx:include fx:id="sidebar" source="SidebarView.fxml"/>
        </left>

        <center>
            <ScrollPane fitToWidth="true"
                        fitToHeight="true"
                        pannable="false"
                        styleClass="center-scroll">
                <content>
                    <StackPane styleClass="result-bg">

                        <VBox alignment="CENTER"
                              spacing="20"
                              maxWidth="680"
                              styleClass="result-container">

                            <padding>
                                <Insets top="60" right="40" bottom="60" left="40"/>
                            </padding>

                            <HBox alignment="CENTER_LEFT" styleClass="result-header-bar">

                                <Button onAction="#handleBack" styleClass="result-back-btn">
                                    <graphic>
                                        <ImageView fitWidth="20" fitHeight="20" preserveRatio="true">
                                            <image>
                                                <Image url="@/icons/back-arrow.png"/>
                                            </image>
                                        </ImageView>
                                    </graphic>
                                </Button>

                                <Label text="%result_title"
                                       styleClass="result-header-title"
                                       HBox.hgrow="ALWAYS"
                                       maxWidth="Infinity"
                                       alignment="CENTER"/>

                                <Region minWidth="38" maxWidth="38"/>

                            </HBox>

                            <HBox alignment="CENTER" spacing="0"
                                  styleClass="result-symptoms-wrapper">

                                <VBox fx:id="symptomsBox"
                                      alignment="TOP_LEFT"
                                      spacing="10"
                                      HBox.hgrow="ALWAYS"
                                      styleClass="result-symptoms-box"/>

                                <VBox alignment="CENTER" styleClass="result-speaker-box">
                                    <Button fx:id="speakerBtn"
                                            styleClass="result-speaker-btn"
                                            onAction="#handleSpeak">
                                        <graphic>
                                            <ImageView fx:id="speakerIcon"
                                                       fitWidth="32" fitHeight="32"
                                                       preserveRatio="true">
                                                <image>
                                                    <Image url="@/icons/speaker.png"/>
                                                </image>
                                            </ImageView>
                                        </graphic>
                                    </Button>
                                </VBox>

                            </HBox>

                            <HBox alignment="CENTER_RIGHT" spacing="20">
                                <Label text="%result_match_question"
                                       styleClass="result-match-label"/>
                                <Button text="%result_yes"
                                        styleClass="result-yes-btn"
                                        onAction="#handleYes"/>
                                <Button text="%result_no"
                                        styleClass="result-no-btn"
                                        onAction="#handleNo"/>
                            </HBox>

                        </VBox>

                    </StackPane>
                </content>
            </ScrollPane>
        </center>

    </BorderPane>

</StackPane>
