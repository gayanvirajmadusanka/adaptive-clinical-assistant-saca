<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<AnchorPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.saca.controller.WelcomeController"
            prefWidth="1000"
            prefHeight="650"
            stylesheets="@/styles/style.css"
            styleClass="root">

    <children>

        <!-- Main horizontal layout -->
        <HBox alignment="CENTER"
              spacing="80"
              AnchorPane.topAnchor="0.0"
              AnchorPane.bottomAnchor="0.0"
              AnchorPane.leftAnchor="0.0"
              AnchorPane.rightAnchor="0.0">

            <children>

                <!-- App LOGO -->
                <VBox alignment="CENTER"
                      prefWidth="350">

                    <children>
                        <ImageView fitWidth="280"
                                   fitHeight="280"
                                   preserveRatio="true">

                            <image>
                                <Image url="@/images/app-logo.png"/>
                            </image>

                        </ImageView>
                    </children>

                </VBox>

                <!-- Right side content -->
                <VBox alignment="CENTER"
                      spacing="20"
                      prefWidth="400">

                    <children>

                        <!-- Welcome text -->
                        <Label text="Welcome"
                               styleClass="welcome-title"
                               alignment="CENTER"
                               textAlignment="CENTER"
                               maxWidth="Infinity"/>

                        <!-- Welcome  Warlpiri-->
                        <Label text="Nyampu nyuntu karrimi"
                               styleClass="subtitle"
                               alignment="CENTER"
                               textAlignment="CENTER"
                               maxWidth="Infinity"/>

                        <!-- Start Button -->
                        <Button prefWidth="350"
                                prefHeight="150"
                                onAction="#handleStartClick"
                                styleClass="start-button">

                            <graphic>
                                <HBox alignment="CENTER" spacing="15">

                                    <!-- Left Icon -->
                                    <ImageView fitWidth="35"
                                               fitHeight="35"
                                               preserveRatio="true">
                                        <image>
                                            <Image url="@/icons/sun.png"/>
                                        </image>
                                    </ImageView>

                                    <!-- Button Text -->
                                    <Label text="Start&#10;Yukami"
                                           alignment="CENTER"
                                           textAlignment="CENTER"
                                           styleClass="button-text"/>

                                    <!-- Right Icon -->
                                    <ImageView fitWidth="35"
                                               fitHeight="35"
                                               preserveRatio="true">
                                        <image>
                                            <Image url="@/icons/sun.png"/>
                                        </image>
                                    </ImageView>

                                </HBox>
                            </graphic>

                        </Button>

                        <!-- About -->
                        <Button text="About SACA (SACA-ku Yimi)"
                                fx:id="aboutButton"
                                onAction="#handleAboutClick"
                                styleClass="about-label"/>

                    </children>

                </VBox>

            </children>

        </HBox>

    </children>

    <padding>
        <Insets top="40" right="40" bottom="40" left="40"/>
    </padding>

</AnchorPane>
